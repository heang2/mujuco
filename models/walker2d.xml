<mujoco model="walker2d">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight ambient="0.3 0.3 0.3" diffuse="0.8 0.8 0.8"/>
    <rgba haze="0.1 0.15 0.2 1"/>
    <quality shadowsize="2048"/>
  </visual>

  <default>
    <joint limited="true" damping="0.1" armature="0.01" stiffness="0"/>
    <geom condim="3" friction="0.9 0.1 0.1"
          solimp="0.9 0.95 0.001" solref="0.02 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="100"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0.05 0.05 0.05" width="512" height="3072"/>
    <texture name="floor_tex" type="2d" builtin="checker"
             rgb1="0.2 0.3 0.2" rgb2="0.12 0.18 0.12" width="256" height="256"/>
    <material name="floor_mat"   texture="floor_tex" texrepeat="10 10"/>
    <material name="torso_mat"   rgba="0.35 0.60 0.90 1"/>
    <material name="rthigh_mat"  rgba="0.20 0.50 0.80 1"/>
    <material name="rleg_mat"    rgba="0.10 0.40 0.70 1"/>
    <material name="rfoot_mat"   rgba="0.80 0.45 0.10 1"/>
    <material name="lthigh_mat"  rgba="0.15 0.55 0.85 1"/>
    <material name="lleg_mat"    rgba="0.05 0.35 0.65 1"/>
    <material name="lfoot_mat"   rgba="0.70 0.38 0.08 1"/>
  </asset>

  <worldbody>
    <light name="top"   pos="0 0 7"  dir="0 0 -1"    diffuse="0.6 0.6 0.6" castshadow="true"/>
    <light name="side1" pos="4 0 5"  dir="-0.6 0 -0.8" diffuse="0.3 0.3 0.3"/>
    <geom  name="floor" type="plane" size="50 10 0.1" material="floor_mat"/>

    <!-- Torso — slides in x and z, rotates about y (sagittal plane) -->
    <body name="torso" pos="0 0 1.25">
      <joint name="rootx" type="slide" axis="1 0 0" limited="false" damping="0" armature="0"/>
      <joint name="rootz" type="slide" axis="0 0 1" limited="false" damping="0" armature="0"/>
      <joint name="rooty" type="hinge" axis="0 1 0" limited="false" damping="0" armature="0"/>
      <geom  name="torso_geom" type="capsule" fromto="0 0 0.15  0 0 0.55"
             size="0.07" material="torso_mat" mass="8.0"/>
      <geom  name="head_geom"  type="sphere"  pos="0 0 0.60" size="0.07"
             rgba="0.95 0.75 0.3 1" mass="0.8"/>

      <!-- Right leg -->
      <body name="right_thigh" pos="0 -0.09 0.15">
        <joint name="right_hip"   type="hinge" axis="0 1 0" range="-1.047 2.094" damping="2.0"/>
        <geom  name="right_thigh" type="capsule" fromto="0 0 0  0 0 -0.45"
               size="0.05" material="rthigh_mat" mass="2.0"/>
        <body  name="right_leg" pos="0 0 -0.45">
          <joint name="right_knee"  type="hinge" axis="0 1 0" range="-1.745 -0.05" damping="2.0"/>
          <geom  name="right_leg"   type="capsule" fromto="0 0 0  0 0 -0.37"
                 size="0.04" material="rleg_mat" mass="1.2"/>
          <body  name="right_foot" pos="0 0 -0.37">
            <joint name="right_ankle" type="hinge" axis="0 1 0" range="-0.698 0.524" damping="2.0"/>
            <geom  name="right_foot"  type="capsule" fromto="-0.04 0 0  0.24 0 0"
                   size="0.04" material="rfoot_mat" mass="0.5" friction="1.5 0.1 0.1"/>
          </body>
        </body>
      </body>

      <!-- Left leg -->
      <body name="left_thigh" pos="0 0.09 0.15">
        <joint name="left_hip"    type="hinge" axis="0 1 0" range="-1.047 2.094" damping="2.0"/>
        <geom  name="left_thigh"  type="capsule" fromto="0 0 0  0 0 -0.45"
               size="0.05" material="lthigh_mat" mass="2.0"/>
        <body  name="left_leg" pos="0 0 -0.45">
          <joint name="left_knee"   type="hinge" axis="0 1 0" range="-1.745 -0.05" damping="2.0"/>
          <geom  name="left_leg"    type="capsule" fromto="0 0 0  0 0 -0.37"
                 size="0.04" material="lleg_mat" mass="1.2"/>
          <body  name="left_foot" pos="0 0 -0.37">
            <joint name="left_ankle"  type="hinge" axis="0 1 0" range="-0.698 0.524" damping="2.0"/>
            <geom  name="left_foot"   type="capsule" fromto="-0.04 0 0  0.24 0 0"
                   size="0.04" material="lfoot_mat" mass="0.5" friction="1.5 0.1 0.1"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <motor name="right_hip_act"   joint="right_hip"   gear="100"/>
    <motor name="right_knee_act"  joint="right_knee"  gear="100"/>
    <motor name="right_ankle_act" joint="right_ankle" gear="100"/>
    <motor name="left_hip_act"    joint="left_hip"    gear="100"/>
    <motor name="left_knee_act"   joint="left_knee"   gear="100"/>
    <motor name="left_ankle_act"  joint="left_ankle"  gear="100"/>
  </actuator>

  <sensor>
    <jointpos name="rh_pos"  joint="right_hip"/>
    <jointpos name="rk_pos"  joint="right_knee"/>
    <jointpos name="ra_pos"  joint="right_ankle"/>
    <jointpos name="lh_pos"  joint="left_hip"/>
    <jointpos name="lk_pos"  joint="left_knee"/>
    <jointpos name="la_pos"  joint="left_ankle"/>
    <jointvel name="rh_vel"  joint="right_hip"/>
    <jointvel name="rk_vel"  joint="right_knee"/>
    <jointvel name="ra_vel"  joint="right_ankle"/>
    <jointvel name="lh_vel"  joint="left_hip"/>
    <jointvel name="lk_vel"  joint="left_knee"/>
    <jointvel name="la_vel"  joint="left_ankle"/>
  </sensor>
</mujoco>
