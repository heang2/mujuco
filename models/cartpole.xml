<mujoco model="cartpole">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.02" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="cart_mat" rgba="0.3 0.5 0.8 1"/>
    <material name="pole_mat" rgba="0.85 0.35 0.1 1"/>
    <material name="rail_mat" rgba="0.6 0.6 0.6 1"/>
  </asset>

  <worldbody>
    <light name="top" pos="0 0 5" dir="0 0 -1" directional="true" diffuse="0.7 0.7 0.7" specular="0.1 0.1 0.1"/>
    <geom name="floor" type="plane" size="10 10 0.1" material="groundplane" pos="0 0 -0.15"/>

    <!-- Rail / track -->
    <geom name="rail_left"  type="cylinder" fromto="-3 0 0  -3 0 0.01" size="0.02" material="rail_mat"/>
    <geom name="rail_right" type="cylinder" fromto=" 3 0 0   3 0 0.01" size="0.02" material="rail_mat"/>
    <geom name="rail_bar"   type="capsule"  fromto="-3 0 0.005  3 0 0.005" size="0.012" material="rail_mat"/>

    <!-- Cart body -->
    <body name="cart" pos="0 0 0">
      <joint name="slider" type="slide" axis="1 0 0" range="-3.0 3.0" damping="0.5"/>
      <geom name="cart_body" type="box" size="0.18 0.08 0.06" pos="0 0 0.06" material="cart_mat" mass="1.0"/>
      <geom name="wheel_fl" type="cylinder" fromto="-0.12 -0.09 0.025  -0.12 -0.12 0.025" size="0.025" rgba="0.2 0.2 0.2 1"/>
      <geom name="wheel_fr" type="cylinder" fromto=" 0.12 -0.09 0.025   0.12 -0.12 0.025" size="0.025" rgba="0.2 0.2 0.2 1"/>
      <geom name="wheel_bl" type="cylinder" fromto="-0.12  0.09 0.025  -0.12  0.12 0.025" size="0.025" rgba="0.2 0.2 0.2 1"/>
      <geom name="wheel_br" type="cylinder" fromto=" 0.12  0.09 0.025   0.12  0.12 0.025" size="0.025" rgba="0.2 0.2 0.2 1"/>

      <!-- Pole -->
      <body name="pole" pos="0 0 0.12">
        <joint name="hinge" type="hinge" axis="0 1 0" damping="0.002"/>
        <geom name="pole_geom" type="capsule" fromto="0 0 0  0 0 0.7" size="0.022" material="pole_mat" mass="0.12"/>
        <geom name="pole_tip" type="sphere" pos="0 0 0.7" size="0.035" rgba="1.0 0.9 0.0 1" mass="0.01"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="slide_motor" joint="slider" gear="25" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>

  <sensor>
    <jointpos  name="cart_pos"  joint="slider"/>
    <jointvel  name="cart_vel"  joint="slider"/>
    <jointpos  name="pole_ang"  joint="hinge"/>
    <jointvel  name="pole_vel"  joint="hinge"/>
  </sensor>
</mujoco>
